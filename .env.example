# =============================================================================
# AI Financial Document Analyst — Environment Configuration (EXAMPLE)
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Every variable here is consumed by backend/app/core/config.py (Pydantic Settings).
# =============================================================================

# ---- Runtime environment -----------------------------------------------------
# One of: local | development | production
APP_ENV=local
# Human-readable service name (appears in logs and /status)
APP_NAME=ai-financial-document-analyst
# Debug toggles verbose logging + auto-reload. NEVER true in production.
DEBUG=true
# Logging: DEBUG | INFO | WARNING | ERROR ; format: json | console
LOG_LEVEL=INFO
LOG_FORMAT=console

# ---- API ---------------------------------------------------------------------
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins (frontend dev server, etc.)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- PostgreSQL + pgvector ---------------------------------------------------
# Async SQLAlchemy URL (note the +asyncpg driver).
DATABASE_URL=postgresql+asyncpg://analyst:analyst@postgres:5432/financial_analyst
# Sync URL used by Alembic migrations (psycopg).
DATABASE_URL_SYNC=postgresql+psycopg://analyst:analyst@postgres:5432/financial_analyst
# Connection pool tuning
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ---- Redis (Celery broker + result backend + future cache) -------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- LLM / Embedding providers ----------------------------------------------
# Primary LLM + embeddings (Google Gemini)
GEMINI_API_KEY=changeme
GEMINI_LLM_MODEL=gemini-2.5-pro
# NOTE: embedding *model variant* and *dimension* are intentionally TBD until
# Phase 2 (see docs/02_DATABASE_DESIGN.md §6.1). Leave EMBEDDING_DIM unset.
GEMINI_EMBEDDING_MODEL=
EMBEDDING_DIM=

# Fallback LLM (GPT-4o via OpenRouter)
OPENROUTER_API_KEY=changeme
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o

# ---- Security / Auth (NOT implemented yet — Phase 11) -----------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme-please-generate-a-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Object storage (raw documents) -----------------------------------------
# Local FS path in dev; S3-compatible config in staging/prod.
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/uploads
# S3 (used when STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
